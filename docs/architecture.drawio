        <mxCell id="npcap" value="Npcap (driver de captura)&#10;requerido en Windows para ARP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0eafb;strokeColor=#c9b8ec;" vertex="1" parent="1">
